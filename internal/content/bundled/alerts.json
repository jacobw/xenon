[
  {
    "id": "temp-high",
    "severity": "warning",
    "summary": "High temperature on {{device}} \u00b7 {{component_name}} ({{value}} \u00b0C)",
    "expr": "components_component_state_temperature_instant > 45"
  },
  {
    "id": "interface-flapping",
    "severity": "warning",
    "summary": "{{interface_name}} on {{device}} has flapped {{value}} times",
    "expr": "interfaces_interface_state_counters_carrier_transitions > 10"
  },
  {
    "id": "cpu-high",
    "severity": "critical",
    "summary": "High CPU on {{device}} ({{value}} %)",
    "expr": "(100 - system_cpus_cpu_state_idle_instant) > 80"
  },
  {
    "id": "optic-rx-low",
    "severity": "warning",
    "summary": "Low optical Rx on {{device}} \u00b7 {{component_name}} ({{value}} dBm)",
    "expr": "components_component_transceiver_state_input_power_instant < -14"
  },
  {
    "id": "interface-errors",
    "severity": "warning",
    "summary": "Interface errors on {{device}} \u00b7 {{interface_name}} ({{value}}/s)",
    "expr": "sum by (device, interface_name) (rate(interfaces_interface_state_counters_in_errors[5m]) + rate(interfaces_interface_state_counters_out_errors[5m]) + rate(interfaces_interface_state_counters_in_discards[5m]) + rate(interfaces_interface_state_counters_out_discards[5m])) > 1"
  }
]
